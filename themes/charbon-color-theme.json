  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#ead9d477",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comment",
      "scope": ["comment.block.documentation"],
      "settings": {
        "foreground": "#e07a5acc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#ead9d4"
      }
    },
    {
      "name": "Variable — parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#c8b3ab",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — language (this, self, super)",
      "scope": ["variable.language", "variable.language.this"],
      "settings": {
        "foreground": "#e8909f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — other (member, property reads)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "Keyword (control, import, etc.)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.import"
      ],
      "settings": {
        "foreground": "#e8909f"
      }
    },
    {
      "name": "Storage (const, let, function, class)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#e07a5a"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#c8b3ab"
      }
    },
    {
      "name": "Operator — new, typeof, instanceof (word-shaped)",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.delete",
        "keyword.operator.in"
      ],
      "settings": {
        "foreground": "#e8909f"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "String — punctuation (quotes)",
      "scope": [
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#e07a5a"
      }
    },
    {
      "name": "String — escape",
      "scope": ["constant.character.escape", "constant.character"],
      "settings": {
        "foreground": "#e07a5a"
      }
    },
    {
      "name": "String — template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#e07a5a"
      }
    },
    {
      "name": "Number / numeric constant",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "Language constant (true, false, null, undefined)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#e8909f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function — definition",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#ead9d4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function — call",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "Class / type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.namespace",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#c8b3ab",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type — primitive",
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#c8b3ab"
      }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#e8c267",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#ead9d499"
      }
    },
    {
      "name": "Arrow function",
      "scope": ["storage.type.function.arrow"],
      "settings": {
        "foreground": "#e8909f"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#2a2018",
        "background": "#e8909f"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#e8909f",
        "fontStyle": "italic"
      }
    },

    {
      "name": "JSX/HTML tag",
      "scope": [
        "entity.name.tag",
        "meta.tag punctuation.definition.tag",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#e07a5a"
      }
    },
    {
      "name": "JSX/HTML tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#ead9d488"
      }
    },
    {
      "name": "HTML attribute name",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#e8c267",
        "fontStyle": "italic"
      }
    },

    {
      "name": "CSS selector — element",
      "scope": ["entity.name.tag.css"],
      "settings": {
        "foreground": "#e07a5a"
      }
    },
    {
      "name": "CSS selector — class",
      "scope": ["entity.other.attribute-name.class.css"],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "CSS selector — id",
      "scope": ["entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#e8909f"
      }
    },
    {
      "name": "CSS selector — pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#e8c267",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": {
        "foreground": "#c8b3ab"
      }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css", "meta.property-value.css"],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "CSS unit",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#e8909f"
      }
    },
    {
      "name": "CSS variable",
      "scope": ["variable.argument.css", "variable.other.custom-property.css"],
      "settings": {
        "foreground": "#e07a5a"
      }
    },

    {
      "name": "JSON property",
      "scope": ["support.type.property-name.json", "meta.structure.dictionary.json string.quoted.double.json"],
      "settings": {
        "foreground": "#c8b3ab"
      }
    },

    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml", "string.unquoted.plain.out.yaml"],
      "settings": {
        "foreground": "#e07a5a"
      }
    },

    {
      "name": "Markdown — heading",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#e07a5a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#e8909f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#e8c267",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#c8b3ab",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#e8c267",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown — code (inline + block)",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "Markdown — list punctuation",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": {
        "foreground": "#e07a5a"
      }
    },

    {
      "name": "Diff — header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#c8b3ab"
      }
    },
    {
      "name": "Diff — inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#a3b36b"
      }
    },
    {
      "name": "Diff — deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e8909f"
      }
    },
    {
      "name": "Diff — changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#e8c267"
      }
    },

    {
      "name": "Regex — character class",
      "scope": ["constant.other.character-class.regexp"],
      "settings": {
        "foreground": "#e8c267"
      }
    },
    {
      "name": "Regex — group",
      "scope": [
        "punctuation.definition.group.regexp",
        "meta.group.regexp"
      ],
      "settings": {
        "foreground": "#e07a5a"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#c8b3ab",
    "type": { "foreground": "#c8b3ab", "bold": true },
    "class": { "foreground": "#c8b3ab", "bold": true },
    "interface": { "foreground": "#c8b3ab", "bold": true },
    "enum": { "foreground": "#c8b3ab", "bold": true },
    "typeParameter": { "foreground": "#e8909f", "italic": true },
    "function": { "foreground": "#ead9d4", "bold": true },
    "method": { "foreground": "#e8c267" },
    "macro": "#e07a5a",
    "variable": "#ead9d4",
    "variable.readonly": "#e8c267",
    "parameter": { "foreground": "#c8b3ab", "italic": true },
    "property": "#e8c267",
    "enumMember": "#e8c267",
    "event": "#e07a5a",
    "decorator": { "foreground": "#e8c267", "italic": true },
    "keyword": "#e8909f",
    "string": "#e8c267",
    "number": "#e8c267",
    "regexp": "#e8c267",
    "operator": "#c8b3ab",
    "*.defaultLibrary": "#c8b3ab",
    "*.deprecated": { "strikethrough": true, "foreground": "#e8909f" }
  }
}
