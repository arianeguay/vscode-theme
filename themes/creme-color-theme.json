  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#8a7560",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation comment",
      "scope": ["comment.block.documentation"],
      "settings": {
        "foreground": "#9b4528",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#2a2018"
      }
    },
    {
      "name": "Variable — parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#4a3d31",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — language (this, self, super)",
      "scope": ["variable.language", "variable.language.this"],
      "settings": {
        "foreground": "#7a1f3d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — other (member, property reads)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "variable.other.property",
        "variable.other.object.property"
      ],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "Keyword (control, import, etc.)",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "keyword.import"
      ],
      "settings": {
        "foreground": "#7a1f3d"
      }
    },
    {
      "name": "Storage (const, let, function, class)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.logical",
        "keyword.operator.relational",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#4a3d31"
      }
    },
    {
      "name": "Operator — new, typeof, instanceof (word-shaped)",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.delete",
        "keyword.operator.in"
      ],
      "settings": {
        "foreground": "#7a1f3d"
      }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "String — punctuation (quotes)",
      "scope": [
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#c96442"
      }
    },
    {
      "name": "String — escape",
      "scope": ["constant.character.escape", "constant.character"],
      "settings": {
        "foreground": "#dba636"
      }
    },
    {
      "name": "String — template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#c96442"
      }
    },
    {
      "name": "Number / numeric constant",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "Language constant (true, false, null, undefined)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#7a1f3d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function — definition",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#2a2018",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function — call",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function",
        "variable.function"
      ],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "Class / type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.namespace",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#4a3d31",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type — primitive",
      "scope": [
        "support.type.primitive",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#4a3d31"
      }
    },
    {
      "name": "Decorator",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#dba636",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.section",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6d5e51"
      }
    },
    {
      "name": "Arrow function",
      "scope": ["storage.type.function.arrow"],
      "settings": {
        "foreground": "#7a1f3d"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#faf6ed",
        "background": "#7a1f3d"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#7a1f3d",
        "fontStyle": "italic"
      }
    },

    {
      "name": "JSX/HTML tag",
      "scope": [
        "entity.name.tag",
        "meta.tag punctuation.definition.tag",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "JSX/HTML tag punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#6d5e51"
      }
    },
    {
      "name": "HTML attribute name",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7a1f3d",
        "fontStyle": "italic"
      }
    },

    {
      "name": "CSS selector — element",
      "scope": ["entity.name.tag.css"],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "CSS selector — class",
      "scope": ["entity.other.attribute-name.class.css"],
      "settings": {
        "foreground": "#7a1f3d"
      }
    },
    {
      "name": "CSS selector — id",
      "scope": ["entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#dba636"
      }
    },
    {
      "name": "CSS selector — pseudo",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#9b4528",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "meta.property-name.css"],
      "settings": {
        "foreground": "#4a3d31"
      }
    },
    {
      "name": "CSS value",
      "scope": ["support.constant.property-value.css", "meta.property-value.css"],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "CSS unit",
      "scope": ["keyword.other.unit.css"],
      "settings": {
        "foreground": "#7a1f3d"
      }
    },
    {
      "name": "CSS variable",
      "scope": ["variable.argument.css", "variable.other.custom-property.css"],
      "settings": {
        "foreground": "#c96442"
      }
    },

    {
      "name": "JSON property",
      "scope": ["support.type.property-name.json", "meta.structure.dictionary.json string.quoted.double.json"],
      "settings": {
        "foreground": "#4a3d31"
      }
    },

    {
      "name": "YAML key",
      "scope": ["entity.name.tag.yaml", "string.unquoted.plain.out.yaml"],
      "settings": {
        "foreground": "#9b4528"
      }
    },

    {
      "name": "Markdown — heading",
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "punctuation.definition.heading"
      ],
      "settings": {
        "foreground": "#c96442",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#7a1f3d",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#9b4528",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#4a3d31",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#9b4528",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown — code (inline + block)",
      "scope": ["markup.inline.raw", "markup.raw.block"],
      "settings": {
        "foreground": "#9b4528"
      }
    },
    {
      "name": "Markdown — list punctuation",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": {
        "foreground": "#c96442"
      }
    },

    {
      "name": "Diff — header",
      "scope": ["meta.diff", "meta.diff.header"],
      "settings": {
        "foreground": "#4a3d31"
      }
    },
    {
      "name": "Diff — inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#5d6b35"
      }
    },
    {
      "name": "Diff — deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#7a1f3d"
      }
    },
    {
      "name": "Diff — changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#9b4528"
      }
    },

    {
      "name": "Regex — character class",
      "scope": ["constant.other.character-class.regexp"],
      "settings": {
        "foreground": "#dba636"
      }
    },
    {
      "name": "Regex — group",
      "scope": [
        "punctuation.definition.group.regexp",
        "meta.group.regexp"
      ],
      "settings": {
        "foreground": "#c96442"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#4a3d31",
    "type": { "foreground": "#4a3d31", "bold": true },
    "class": { "foreground": "#4a3d31", "bold": true },
    "interface": { "foreground": "#4a3d31", "bold": true },
    "enum": { "foreground": "#4a3d31", "bold": true },
    "typeParameter": { "foreground": "#7a1f3d", "italic": true },
    "function": { "foreground": "#2a2018", "bold": true },
    "method": { "foreground": "#9b4528" },
    "macro": "#dba636",
    "variable": "#2a2018",
    "variable.readonly": "#9b4528",
    "parameter": { "foreground": "#4a3d31", "italic": true },
    "property": "#9b4528",
    "enumMember": "#9b4528",
    "event": "#c96442",
    "decorator": { "foreground": "#dba636", "italic": true },
    "keyword": "#7a1f3d",
    "string": "#9b4528",
    "number": "#9b4528",
    "regexp": "#dba636",
    "operator": "#4a3d31",
    "*.defaultLibrary": "#4a3d31",
    "*.deprecated": { "strikethrough": true, "foreground": "#7a1f3d" }
  }
}
